<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageIcon>RandomRPG.ico</PackageIcon>
    <StartupObject>RandomRPG.RPG</StartupObject>
    <ApplicationIcon>RandomRPG.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="RandomRPG.ico" />
  </ItemGroup>

  <ItemGroup>
    <None Update="RandomRPG.ico">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Properties\" />
  </ItemGroup>

</Project>
